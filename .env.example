# ── Google Sheets ─────────────────────────────────────────
# Service Account JSON (base64 encoded)
# Como gerar: Google Cloud Console → IAM → Service Accounts → Create Key → JSON
# Encode: base64 -i credentials.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=

# ID da planilha (retirar da URL: docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=

# ── Supabase ───────────────────────────────────────────────
# Criar projeto em supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── ZIG API ───────────────────────────────────────────────
ZIG_TOKEN=
ZIG_BASE_URL=https://api.zigcore.com.br/integration
ZIG_REDE_ID=quintal

# ── Protheus (futuro) ─────────────────────────────────────
# PROTHEUS_URL=
# PROTHEUS_USER=
# PROTHEUS_PASS=

# ── App ───────────────────────────────────────────────────
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000
